# Copier en `.env` et renseigner. Ne JAMAIS committer le .env ni la clé JSON.

# Chemin vers la clé service account Firebase (Console Firebase →
# Paramètres du projet → Comptes de service → Générer une nouvelle clé privée).
SERVICE_ACCOUNT_PATH=./service-account.json

# Id de la cuisine à écouter = champ `kitchenOperatorId` des commandes
# (= claim `kitchen_operator_id` du compte cuisine dans l'app). Doc dans la
# collection `kitchenOperators`.
KITCHEN_OPERATOR_ID=

# ── Imprimantes (deux profils possibles si les deux sont branchées) ───────────
# Format : clé=nom_file_CUPS:format_papier  (séparés par des virgules)
# Formats : 100x150 (étiquettes Munbyn) | 80mm (rouleau thermique POS80)
PRINTERS=munbyn:Munbyn:100x150,pos80:POS80:80mm

# Imprimante utilisée par le service (clé parmi PRINTERS)
ACTIVE_PRINTER=munbyn

# Rétrocompatibilité : si PRINTERS est absent, PRINTER_NAME seul suffit.
# PRINTER_NAME=Munbyn

# Délai entre deux impressions successives (ms) — anti-saturation imprimante.
PRINT_DELAY_MS=1200

# ── Rendu du ticket (rouleau) ────────────────────────────────────────────────
# Échelle de TOUTES les polices (proportions conservées). 1 = origine.
# TICKET_FONT_SCALE=1.15

# Largeur réellement imprimable de la tête (mm), souvent < largeur papier.
# Réduire si le texte est coupé à droite ; augmenter si trop de marge.
# ROLL_PRINT_WIDTH_MM=72

# ── Impression ESC/POS (rouleau thermique POS80) ─────────────────────────────
# Le format « 80mm » imprime par défaut en trame ESC/POS brute (GS v 0 + coupe) :
# la hauteur suit EXACTEMENT le contenu et la coupe tombe juste après le ticket,
# sans page fixe ni marge du driver CUPS/PDF. Les étiquettes Munbyn (100x150)
# restent en CUPS/PDF.
#
# Forcer un mode quel que soit le format : escpos | pdf (défaut = suit le format).
# PRINT_MODE=escpos
#
# Largeur d'impression en points (203 dpi) : 576 = 72 mm imprimables.
# Réduire si le texte est coupé à droite ; multiple de 8 conseillé.
# ESCPOS_WIDTH_DOTS=576
#
# Seuil de binarisation noir/blanc (0-255). Plus haut = plus de noir/gras.
# ESCPOS_THRESHOLD=180
#
# Avance papier (points) avant la coupe. 24 ≈ 3 mm. Augmenter si la coupe
# rogne le bas du ticket.
# ESCPOS_CUT_FEED_DOTS=24

# ── Options `lp` (chemin CUPS/PDF uniquement : étiquettes Munbyn) ─────────────
# Sans effet en ESC/POS (envoi `-o raw`). Pour le rouleau, tout se règle via les
# variables ESCPOS_* ci-dessus.
# LP_OPTIONS=-o FeedDist=0feed10mm
