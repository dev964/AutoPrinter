# Copier en `.env` et renseigner. Ne JAMAIS committer le .env ni la clé JSON.

# Chemin vers la clé service account Firebase (Console Firebase →
# Paramètres du projet → Comptes de service → Générer une nouvelle clé privée).
SERVICE_ACCOUNT_PATH=./service-account.json

# Id de la cuisine à écouter = champ `kitchenOperatorId` des commandes
# (= claim `kitchen_operator_id` du compte cuisine dans l'app). Doc dans la
# collection `kitchenOperators`.
KITCHEN_OPERATOR_ID=

# ── Imprimantes (deux profils possibles si les deux sont branchées) ───────────
# Format : clé=nom_file_CUPS:format_papier  (séparés par des virgules)
# Formats : 100x150 (étiquettes Munbyn) | 80mm (rouleau thermique POS80)
PRINTERS=munbyn:Munbyn:100x150,pos80:POS80:80mm

# Imprimante utilisée par le service (clé parmi PRINTERS)
ACTIVE_PRINTER=munbyn

# Rétrocompatibilité : si PRINTERS est absent, PRINTER_NAME seul suffit.
# PRINTER_NAME=Munbyn

# Délai entre deux impressions successives (ms) — anti-saturation imprimante.
PRINT_DELAY_MS=1200
